{
  "name": "balance-web",
  "version": "1.0.0",
  "description": "Balance time-tracking web interface",
  "scripts": {
    "tailwind": "npx tailwindcss -i ./web/src/styles.css -o ./web/static/css/output.css",
    "tailwind:watch": "npx tailwindcss -i ./web/src/styles.css -o ./web/static/css/output.css --watch",
    "esbuild": "./node_modules/.bin/esbuild web/src/ts/* --bundle --outdir=web/static/js"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.20.0",
    "tailwindcss": "^3.4.1"
  },
  "dependencies": {
    "htmx.org": "^1.9.10"
  }
}
